# Python cache files
*.pyc
__pycache__/
*.pyo
*.pyd

# Build and dist
dist/
build/
*.egg
*.egg-info/

# Logs
*.log

# IDE and OS
.DS_Store
.vscode/
.idea/

# Ignore everything in mmdetection3d except configs
mmdetection3d/*
!mmdetection3d/configs/

# Ignore subdirectories in configs that we don't want
mmdetection3d/configs/*/
!mmdetection3d/configs/_base_/
!mmdetection3d/configs/geoheightbev/

# Ignore large checkpoint files
*.pth
